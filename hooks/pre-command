#!/usr/bin/env bash
set -euo pipefail

echo "~~~ :mise: Setup mise"

plugin_cfg() {
  local key
  local local_var_name
  local normalized_key
  local var_name

  key="$1"
  normalized_key="$(printf '%s' "$key" | tr '[:lower:]' '[:upper:]' | tr '-' '_')"
  var_name="BUILDKITE_PLUGIN_MISE_${normalized_key}"
  if [ -n "${!var_name:-}" ]; then
    printf '%s' "${!var_name}"
    return
  fi

  # Local plugin paths like `./:` expose config as BUILDKITE_PLUGIN__*.
  local_var_name="BUILDKITE_PLUGIN__${normalized_key}"
  printf '%s' "${!local_var_name:-}"
}

plugin_cfg_default() {
  local value
  value="$(plugin_cfg "$1")"
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' "$2"
  fi
}

# Read a list-type plugin config (BUILDKITE_PLUGIN_MISE_<KEY>_0, _1, ...).
# Buildkite encodes YAML arrays as indexed env vars: PLUGIN_KEY_0, PLUGIN_KEY_1, etc.
plugin_cfg_list() {
  local key="$1"
  local i=0
  local val

  while true; do
    val="$(plugin_cfg "${key}-${i}")"
    [ -z "$val" ] && break
    printf '%s\n' "$val"
    i=$((i + 1))
  done
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Required command missing: $1" >&2
    exit 1
  fi
}

append_to_buildkite_env() {
  local line="$1"
  printf '%s\n' "$line" >> "$BUILDKITE_ENV_FILE"
}

append_export() {
  local name="$1"
  local value="$2"
  append_to_buildkite_env "$(printf 'export %s=%q' "$name" "$value")"
}

apply_mise_env() {
  local mise_env_file

  mise_env_file="$(mktemp)"
  run_mise env --shell bash | tee -a "$BUILDKITE_ENV_FILE" > "$mise_env_file"

  # Source the generated exports so later host-side hooks inherit the tool env.
  # shellcheck disable=SC1090
  . "$mise_env_file"
  rm -f "$mise_env_file"
}

cleanup_install_mise() {
  rm -f "$1"
  rm -rf "$2"
}

hosted_cache_volume_root() {
  printf '%s' "${MISE_HOSTED_CACHE_VOLUME_ROOT:-/cache/bkcache}"
}

resolve_mise_dir() {
  local cache_dir_cfg
  local hosted_cache_root

  if [ -n "${MISE_DATA_DIR:-}" ]; then
    MISE_DIR_SOURCE="MISE_DATA_DIR environment variable"
    MISE_DIR="$MISE_DATA_DIR"
    return
  fi

  cache_dir_cfg="$(plugin_cfg cache-dir)"
  if [ -n "$cache_dir_cfg" ]; then
    MISE_DIR_SOURCE="plugin cache-dir configuration"
    MISE_DIR="$cache_dir_cfg"
    return
  fi

  hosted_cache_root="$(hosted_cache_volume_root)"
  if [ "${BUILDKITE_COMPUTE_TYPE:-self-hosted}" = "hosted" ] && [ -d "$hosted_cache_root" ] && [ -w "$hosted_cache_root" ]; then
    MISE_DIR_SOURCE="Buildkite hosted agent cache volume"
    MISE_DIR="${hosted_cache_root}/mise"
    return
  fi

  if [ -n "${XDG_DATA_HOME:-}" ]; then
    MISE_DIR_SOURCE="XDG_DATA_HOME fallback"
    MISE_DIR="${XDG_DATA_HOME}/mise"
    return
  fi

  MISE_DIR_SOURCE="HOME fallback"
  MISE_DIR="${HOME}/.local/share/mise"
}

detect_platform() {
  local os
  local arch
  local musl_suffix

  os=""
  arch=""
  musl_suffix=""

  case "$(uname -s)" in
    Linux)
      os="linux"
      ;;
    Darwin)
      os="macos"
      ;;
    *)
      echo "Unsupported OS: $(uname -s)" >&2
      exit 1
      ;;
  esac

  case "$(uname -m)" in
    x86_64|amd64)
      arch="x64"
      ;;
    arm64|aarch64)
      arch="arm64"
      ;;
    armv7l|armv7)
      arch="armv7"
      ;;
    *)
      echo "Unsupported architecture: $(uname -m)" >&2
      exit 1
      ;;
  esac

  if [ "$os" = linux ] && command -v ldd >/dev/null 2>&1; then
    if ldd --version 2>&1 | grep -qi musl; then
      musl_suffix="-musl"
    fi
  fi

  printf '%s' "${os}-${arch}${musl_suffix}"
}

latest_version() {
  curl -fsSL https://mise.jdx.dev/VERSION | tr -d '\r\n'
}

installed_version() {
  if [ ! -x "$MISE_BINARY" ]; then
    return
  fi

  "$MISE_BINARY" --version 2>/dev/null | awk '{print $2}' | tr -d 'v'
}

install_mise() {
  local version="$1"
  local platform="$2"
  local archive
  local extracted
  local url

  url="https://github.com/jdx/mise/releases/download/v${version}/mise-v${version}-${platform}.tar.gz"
  archive="$(mktemp)"
  extracted="$(mktemp -d)"
  echo "Downloading mise v${version} for ${platform}"

  (
    set -euo pipefail
    trap 'cleanup_install_mise "$archive" "$extracted"' EXIT

    curl -fsSL "$url" > "$archive"
    tar -xzf "$archive" -C "$extracted"

    mkdir -p "$MISE_BIN"
    if [ -x "$extracted/mise/bin/mise" ]; then
      mv "$extracted/mise/bin/mise" "$MISE_BINARY"
    elif [ -x "$extracted/bin/mise" ]; then
      mv "$extracted/bin/mise" "$MISE_BINARY"
    else
      echo "Could not find mise binary in ${url}" >&2
      exit 1
    fi
  )
}

run_mise() {
  local -a mise_env

  if [ ! -x "$MISE_BINARY" ]; then
    echo "mise binary not found at $MISE_BINARY" >&2
    exit 1
  fi

  if [ ! -d "$WORKING_DIRECTORY" ]; then
    echo "dir does not exist: $WORKING_DIRECTORY" >&2
    exit 1
  fi

  mise_env=(
    "MISE_DATA_DIR=$MISE_DIR"
    "MISE_TRUSTED_CONFIG_PATHS=$WORKING_DIRECTORY"
    "MISE_YES=1"
    "PATH=$MISE_BIN:$PATH"
  )

  (
    set -euo pipefail
    cd "$WORKING_DIRECTORY"
    env "${mise_env[@]}" "$MISE_BINARY" "$@"
  )
}

run_with_expanded_group_on_failure() {
  local exit_code

  if "$@"; then
    return 0
  else
    exit_code=$?
  fi

  echo "^^^ +++"
  return "$exit_code"
}

ensure_mise_config_present() {
  if [ -f "$WORKING_DIRECTORY/mise.toml" ] || [ -f "$WORKING_DIRECTORY/.mise.toml" ] || [ -f "$WORKING_DIRECTORY/.tool-versions" ]; then
    return
  fi

  echo "No mise config found in $WORKING_DIRECTORY. Expected one of: mise.toml, .mise.toml, .tool-versions" >&2
  exit 1
}

main() {
  local current_version
  local dir_cfg
  local required_version_raw

  required_version_raw="$(plugin_cfg_default version latest)"
  dir_cfg="$(plugin_cfg dir)"

  if [ -n "$dir_cfg" ]; then
    WORKING_DIRECTORY="$dir_cfg"
  else
    WORKING_DIRECTORY="${BUILDKITE_BUILD_CHECKOUT_PATH:-${PWD}}"
  fi

  resolve_mise_dir
  MISE_BIN="${MISE_DIR}/bin"
  MISE_BINARY="${MISE_BIN}/mise"

  echo "Using mise data dir: ${MISE_DIR} (${MISE_DIR_SOURCE})"

  # Seed mise binary from the system PATH if cache is cold and mise is
  # already installed (e.g., baked into a custom agent image). The version
  # check below will still download if the seeded binary doesn't match.
  if [ ! -x "$MISE_BINARY" ]; then
    local system_mise
    system_mise="$(command -v mise 2>/dev/null || true)"
    if [ -n "$system_mise" ] && [ -x "$system_mise" ]; then
      echo "Seeding mise binary from ${system_mise}"
      mkdir -p "$MISE_BIN"
      cp "$system_mise" "$MISE_BINARY"
      chmod +x "$MISE_BINARY"
    fi
  fi

  if [ "$required_version_raw" = latest ]; then
    VERSION="$(latest_version)"
  else
    VERSION="${required_version_raw#v}"
  fi
  VERSION="${VERSION#v}"

  PLATFORM="$(detect_platform)"
  require_cmd curl
  require_cmd tar

  current_version="$(installed_version)"
  if [ -z "$current_version" ] || [ "$current_version" != "$VERSION" ]; then
    run_with_expanded_group_on_failure install_mise "$VERSION" "$PLATFORM"
  fi

  ensure_mise_config_present

  run_mise --version
  # Selective tool install: when `tools` is configured, only install those
  # specific tools instead of everything in the config file. Useful in
  # monorepos where each step only needs a subset of tools.
  local -a tools_list=()
  while IFS= read -r tool; do
    [ -n "$tool" ] && tools_list+=("$tool")
  done < <(plugin_cfg_list tools)

  if [ "${#tools_list[@]}" -gt 0 ]; then
    echo "Installing tools: ${tools_list[*]}"
    run_with_expanded_group_on_failure run_mise install "${tools_list[@]}"
  else
    run_with_expanded_group_on_failure run_mise install
  fi

  if [ -z "${BUILDKITE_ENV_FILE:-}" ]; then
    echo "BUILDKITE_ENV_FILE is not set" >&2
    exit 1
  fi

  append_export MISE_DATA_DIR "$MISE_DIR"
  append_export MISE_TRUSTED_CONFIG_PATHS "$WORKING_DIRECTORY"
  append_export MISE_YES "1"

  export MISE_DATA_DIR="$MISE_DIR"
  export MISE_TRUSTED_CONFIG_PATHS="$WORKING_DIRECTORY"
  export MISE_YES="1"
  apply_mise_env

  echo "~~~ :white_check_mark: mise setup complete"
}

main "$@"
